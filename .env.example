# Local Development Environment Variables
# Copy this to .env and customize for your local setup
#
# WHY THIS FILE EXISTS:
# - Local dev uses PHP's built-in server which doesn't run Shibboleth
# - Production uses Apache + Shibboleth which sets these automatically via $_SERVER
# - The mere presence of this file unlocks dev.php, which simulates Shibboleth via cookie
#
# USAGE:
# 1. Copy: cp .env.example .env  (setup.ps1 does this automatically)
# 2. Visit dev.php in your browser to switch between test users
# 3. Or use dev.php?user=email to set the mock_mail cookie directly
#
# SETUP GUIDE:
# - Windows: See docs/PROFESSOR-SETUP.md

MAIL=test_mail1@stonybrook.edu
CN=test_cn
NICKNAME=test_nickname
GIVENNAME=test_givenName
SN=test_sn
